NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Next.js Configuration
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your_nextauth_secret

# OpenAI Configuration (opcional)
OPENAI_API_KEY=your_openai_api_key

# ContaAzul Configuration (opcional)
CONTA_AZUL_CLIENT_ID=your_contaazul_client_id
CONTA_AZUL_CLIENT_SECRET=your_contaazul_client_secret

# Meta Configuration (opcional)
META_ACCESS_TOKEN=your_meta_access_token
META_APP_ID=your_meta_app_id

# WhatsApp Configuration (opcional)
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# Discord Configuration (opcional)
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Redis Configuration (opcional)
REDIS_URL=your_redis_url

# Analytics Configuration (opcional)
ANALYTICS_ID=your_analytics_id